# Lambda Container .dockerignore
# This file controls what gets included in the Docker build context for Lambda functions

# Exclude large model files from build context (models downloaded during build)
models_context/
training_data/

# Exclude most of s3_backup, only include specific experiment models
s3_backup/processed_data/
s3_backup/training-data/

# Exclude other AWS containers (keep only lambda)
aws/feature-engineering/
aws/training/
aws/cloudformation/
aws/scripts/

# Exclude cloudflare and other non-essential directories
cloudflare/
.github/
.cursor/

# Exclude temporary and utility files
clear_tables.ps1
deployment.log
docker-compose.training.yml
mypy.ini
response.json
temp_live_prices.json

# Python cache and virtual environments
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt
.tox/

# Testing and coverage
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.mypy_cache
.pytest_cache
.hypothesis

# Logs and temporary files
*.log
*.tmp
*.temp

# Version control
.git/
.gitignore

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# AWS and deployment files
awscliv2.zip
delete_markers.json
versions.json
Items.zip

# Environment files (may contain sensitive data)
.env
.env.*
aws/.env

# Documentation
docs/
README.md
*.md

# Build artifacts
dist/
build/
*.egg-info/

# OS files
Thumbs.db
.DS_Store
