# Ingestion Lambda container .dockerignore
#
# Docker only reads .dockerignore at the build context root. deploy_ingestion.sh backs up the
# repo-root .dockerignore and copies this file there for `docker build` — same pattern as
# aws/lambdas/prediction/container/.dockerignore for the prediction Lambda.
#
# Ingestion does not COPY s3_backup/models; exclude the full local s3 mirror to keep context small.

# Exclude large model files from build context (models downloaded during build)
models_context/
training_data/

# Local S3 mirror / backups (multi-GB; not used by ingestion image)
s3_backup/

# Exclude other AWS containers (keep only lambda)
aws/feature-engineering/
aws/training/
aws/cloudformation/
aws/scripts/
aws/dist/

# Exclude cloudflare, frontend, and other non-essential directories
cloudflare/
frontend/
.github/
.cursor/

# Exclude temporary and utility files
clear_tables.ps1
deployment.log
docker-compose.training.yml
mypy.ini
response.json
temp_live_prices.json

# Python cache and virtual environments
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
.venv-wsl/
pip-log.txt
pip-delete-this-directory.txt
.tox/

# Testing and coverage
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.mypy_cache
.pytest_cache
.hypothesis

# Logs and temporary files
*.log
*.tmp
*.temp

# Version control
.git/
.gitignore

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# AWS and deployment files
awscliv2.zip
delete_markers.json
versions.json
Items.zip

# Environment files (may contain sensitive data)
.env
.env.*
aws/.env

# Documentation
docs/
README.md
*.md

# Build artifacts
dist/
build/
*.egg-info/

# OS files
Thumbs.db
.DS_Store
